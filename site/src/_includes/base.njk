<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} — Raimbaut d'Orange</title>
  <script>try{var t=localStorage.getItem("rb-theme");if(t==="light"||t==="dark")document.documentElement.dataset.theme=t}catch(e){}</script>
  <link rel="preload" href="/fonts/JunicodeVF-Roman.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/JunicodeVF-Italic.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/css/raimbaut.css">
  <meta name="description" content="Édition électronique du chansonnier de Raimbaut d'Orange, troubadour provençal du XIIe siècle : texte occitan, traduction française, remarques et apparat critique.">
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
<header class="masthead">
  <div class="masthead-inner">
    {% set u = page.url %}
    {% set active = "" %}
    {% if u == "/introduction/" or u.startsWith("/avant-propos") %}{% set active = "intro" %}
    {% elif u.startsWith("/chansons") %}{% set active = "chansons" %}
    {% elif u.startsWith("/poetique") or u == "/conclusion/" %}{% set active = "poetique" %}
    {% elif u.startsWith("/bibliographie") or u.startsWith("/abbreviations") or u.startsWith("/manuscrits") or u.startsWith("/index-") %}{% set active = "biblio" %}
    {% endif %}
    <button type="button" class="nav-toggle" id="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="main-nav">
      <span class="nav-toggle-bars" aria-hidden="true"></span>
    </button>
    <a href="/" class="brand">Raimbaut <span class="amp">d'</span>Orange</a>
    <nav id="main-nav" aria-label="Navigation principale">
      <a href="/introduction/"{% if active == "intro" %} aria-current="page"{% endif %}>Introduction</a>
      <a href="/chansons/"{% if active == "chansons" %} aria-current="page"{% endif %}>Chansons</a>
      <a href="/poetique/"{% if active == "poetique" %} aria-current="page"{% endif %}>Poétique</a>
      <a href="/bibliographie/"{% if active == "biblio" %} aria-current="page"{% endif %}>Références</a>
    </nav>
    <button type="button" class="theme-btn" id="theme-btn" aria-label="Thème clair ou sombre" title="Thème : automatique">◐</button>
  </div>
</header>
{% set here = edition.here[page.url] %}
{% if here %}
<div class="subnav">
  <div class="subnav-inner">
    <p class="sn-here">
      <span class="sn-label">{{ here.label }}</span>
      {% if here.incipit %}<span class="sn-incipit" lang="oc">{{ here.incipit }}</span>{% endif %}
    </p>
    {% if here.chapters %}
    <nav class="sn-chapters" aria-label="Chapitres de la poétique">
      {% for c in here.chapters %}
      <a href="{{ c.url }}"{% if page.url == c.url %} aria-current="page"{% endif %} title="{{ c.title }}">{{ c.short }}</a>
      {% endfor %}
    </nav>
    {% endif %}
    {% if here.apparatus %}
    <nav class="sn-chapters sn-apparatus" aria-label="Sections de l'apparat">
      {% for a in here.apparatus %}
      <a href="{{ a.url }}"{% if page.url == a.url %} aria-current="page"{% endif %}>{{ a.short }}</a>
      {% endfor %}
    </nav>
    {% endif %}
    {% if here.hasViews %}
    <div class="view-control" role="group" aria-label="Version de lecture" hidden>
      <div class="vc-primary">
        <button type="button" data-view="web" aria-pressed="true"><span class="vc-pre">Version </span>web</button>
        <button type="button" data-view="livre" aria-pressed="false"><span class="vc-pre">Version </span>livre</button>
      </div>
      {% if here.hasFacsimile %}
      <div class="vc-secondary" hidden>
        <button type="button" data-livre="continue" aria-pressed="true"><span class="vc-long">Lecture continue</span><span class="vc-short">Continu</span></button>
        <button type="button" data-livre="facsimile" aria-pressed="false"><span class="vc-long">Fac-similé paginé</span><span class="vc-short">Fac-similé</span></button>
      </div>
      {% endif %}
    </div>
    {% elif here.apparatus %}
    {# apparatus pages without a version toggle (Manuscrits, Sigles) reserve the
       toggle's slot with an inert copy, so the apparatus switcher stays in the
       same place across all Références pages whether or not versions can switch. #}
    <div class="view-control view-control--placeholder" aria-hidden="true" inert>
      <div class="vc-primary">
        <button type="button" tabindex="-1"><span class="vc-pre">Version </span>web</button>
        <button type="button" tabindex="-1"><span class="vc-pre">Version </span>livre</button>
      </div>
    </div>
    {% endif %}
  </div>
</div>
{% endif %}
{{ content | safe }}
{% set bpp = edition.pager[page.url] %}
{% if bpp %}
<nav class="book-pager" aria-label="Navigation séquentielle">
  <div class="bp-inner">
    {% if bpp.prevUrl %}<a class="bp-prev" href="{{ bpp.prevUrl }}" rel="prev">
      <span class="bp-k"><span class="bp-dir" aria-hidden="true">←</span> Précédent</span>
      <span class="bp-label">{{ bpp.prevLabel }}</span>
    </a>{% else %}<span></span>{% endif %}
    {% if bpp.nextUrl %}<a class="bp-next" href="{{ bpp.nextUrl }}" rel="next">
      <span class="bp-k">Suivant <span class="bp-dir" aria-hidden="true">→</span></span>
      <span class="bp-label">{{ bpp.nextLabel }}</span>
    </a>{% else %}<span></span>{% endif %}
  </div>
</nav>
{% endif %}
<footer class="colophon">
  <p>Raimbaut d'Orange, édition électronique · <a href="/colophon/">Colophon</a></p>
</footer>
<script src="/js/edition.js" defer></script>
</body>
</html>
