---
layout: base.njk
title: Bibliographie
permalink: /bibliographie/
---
<div class="chanson-page section-page" id="study" data-view="web" data-livre="continue">

{# ================================================= VERSION WEB (lecture) #}
{% macro bibEntries(id) %}
{% set list = edition.bibBySection[id] %}
{% if list %}
<ul class="bib-list">
  {% for e in list %}
  <li{% if e.anchor %} id="{{ e.anchor }}"{% endif %}>
    {{ e.text | bibCite | safe }}{% if e.siglum %} <span class="siglum-tag">[{{ e.siglum }}]</span>{% endif %}
    {% if e.reviews.length %}
    <ul class="bib-reviews">
      {% for r in e.reviews %}<li>{{ r.text | bibCite | safe }}</li>{% endfor %}
    </ul>
    {% endif %}
  </li>
  {% endfor %}
</ul>
{% endif %}
{% endmacro %}
<div class="cx-view cx-web study prose-study no-notes">
<main class="study-main">
<article class="prose">
<header class="section-head">
  <span class="u-eyebrow">Références</span>
  <h1>Bibliographie</h1>
</header>

<div class="bib-layout">
<nav class="bib-toc" aria-label="Sommaire de la bibliographie">
  <ol>
    {% for top in edition.bibliography.sections %}
    <li><a href="#{{ top.id }}"><span class="bib-no">{{ top.label }}.</span> {{ top.title }}</a>
      {% if top.children.length %}
      <ol>
        {% for ch in top.children %}
        <li><a href="#{{ ch.id }}"><span class="bib-no">{{ ch.label }}.</span> {{ ch.title }}</a>
          {% if ch.children.length %}
          <ol>
            {% for sub in ch.children %}
            <li><a href="#{{ sub.id }}"><span class="bib-no">{{ sub.label }}.</span> {{ sub.title }}</a></li>
            {% endfor %}
          </ol>
          {% endif %}
        </li>
        {% endfor %}
      </ol>
      {% endif %}
    </li>
    {% endfor %}
  </ol>
</nav>

<div class="bib-body">
  {% for top in edition.bibliography.sections %}
  <section class="bib-top" id="{{ top.id }}">
    <h2><span class="bib-no">{{ top.label }}.</span> {{ top.title }}</h2>
    {{ bibEntries(top.id) }}
    {% for ch in top.children %}
    <section class="bib-sub" id="{{ ch.id }}">
      <h3><span class="bib-no">{{ ch.label }}.</span> {{ ch.title }}</h3>
      {{ bibEntries(ch.id) }}
      {% for sub in ch.children %}
      <section class="bib-subsub" id="{{ sub.id }}">
        <h4><span class="bib-no">{{ sub.label }}.</span> {{ sub.title }}</h4>
        {{ bibEntries(sub.id) }}
      </section>
      {% endfor %}
      {% if ch.id == "raimbaut-b" %}
      {% for c in edition.bibliography.par_chanson %}
      <article class="parchanson" id="pc-{{ c.chanson }}">
        <h4 class="pc-head">Chanson {{ c.chanson }}{% if edition.romanToNum[c.chanson] %} <a class="pc-link" href="/chansons/{{ edition.romanToNum[c.chanson] }}/">l'étude →</a>{% endif %}</h4>
        {% if c.manuscrits_lines.length %}
        <div class="pc-row"><span class="pc-k">Manuscrits</span>
          <ul class="pc-v pc-ms">{% for m in c.manuscrits_lines %}<li>{{ m | bibCite | safe }}</li>{% endfor %}</ul></div>
        {% endif %}
        {% if c.editions.length %}
        <div class="pc-row"><span class="pc-k">Éditions</span>
          <ul class="pc-v pc-cites">{% for x in c.editions %}<li{% if not x.cite %} class="pc-terse"{% endif %}>{{ (x.cite or x.raw) | bibCite | safe }}</li>{% endfor %}</ul></div>
        {% endif %}
        {% if c.etudes.length %}
        <div class="pc-row"><span class="pc-k">Études, commentaires</span>
          <ul class="pc-v pc-cites">{% for x in c.etudes %}<li{% if not x.cite %} class="pc-terse"{% endif %}>{{ (x.cite or x.raw) | bibCite | safe }}</li>{% endfor %}</ul></div>
        {% endif %}
      </article>
      {% endfor %}
      {% endif %}
    </section>
    {% endfor %}
  </section>
  {% endfor %}
</div>
</div>
</article>
</main>
</div>

{# ====================================== VERSION LIVRE — lecture continue #}
{% set bl = edition.biblioLivre %}
<div class="cx-view cx-livre study prose-study is-livre{% if not bl.notes.length %} no-notes{% endif %}">
<main class="study-main">
<article class="prose">
<section class="edition-body">
{{ bl.html | safe }}
</section>
</article>
</main>
{% if bl.notes.length %}
<aside class="study-panel" aria-label="Notes">
  <header class="panel-head">
    <span>Notes</span>
    <button type="button" class="resync" hidden>⟲ suivre le texte</button>
  </header>
  <div class="panel-scroll">
    {% for n in bl.notes %}
    <div class="fnote" id="fn-{{ n.label }}">
      <a class="fnote-n" href="#fnref-{{ n.label }}" aria-label="Retour à l'appel de note {{ n.n }}">{{ n.n }}</a>
      <span>{{ n.html | safe }}</span>
    </div>
    {% endfor %}
  </div>
</aside>
{% endif %}
</div>

{# ===================================== VERSION LIVRE — fac-similé paginé #}
{% if bl.facsimile.length %}
<section class="cx-view cx-facsimile facsimile-body is-livre" aria-label="Fac-similé du tapuscrit">
  {% for pg in bl.facsimile %}
  <article class="fx-page"{% if pg.pid %} id="fx-page-{{ pg.pid }}"{% endif %}>
    <div class="fx-sheet">
      <div class="fx-content">{{ pg.html | safe }}</div>
      {% if pg.notes.length %}
      <div class="fx-notes">
        {% for n in pg.notes %}<p class="fx-note"><span class="fx-n">{{ n.n }}</span>{{ n.html | safe }}</p>{% endfor %}
      </div>
      {% endif %}
    </div>
    {% if pg.folio %}<div class="fx-folio">{{ pg.folio }}.</div>{% endif %}
  </article>
  {% endfor %}
</section>
{% endif %}

</div>
