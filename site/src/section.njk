---
layout: base.njk
pagination:
  data: edition.linearSections
  size: 1
  alias: section
permalink: "/{{ section.slug }}/"
eleventyComputed:
  title: "{{ section.title }}"
  bodyClass: "livre"
---
<div class="study prose-study{% if not section.notes.length %} no-notes{% endif %}" id="study">

<main class="study-main">
<article class="prose">
<header class="section-head">
  {% if section.kind == "conclusion" %}<span class="u-eyebrow">Vers une poétique de Raimbaut d'Orange</span>{% endif %}
  <h1>{{ section.title }}</h1>
  {% if section.subtitle %}<p class="incipit" lang="oc"><em>{{ section.subtitle }}</em></p>{% endif %}
</header>

<section class="edition-body{% if section.kind == 'index' %} index-body{% endif %}">
{{ section.html | safe }}
</section>
</article>
</main>

{% if section.notes.length %}
<aside class="study-panel" id="panel" aria-label="Notes">
  <header class="panel-head">
    <span>Notes</span>
    <button type="button" class="resync" hidden>⟲ suivre le texte</button>
  </header>
  <div class="panel-scroll" id="panel-scroll">
    {% for n in section.notes %}
    <div class="fnote" id="fn-{{ n.label }}">
      <a class="fnote-n" href="#fnref-{{ n.label }}" aria-label="Retour à l'appel de note {{ n.n }}">{{ n.n }}</a>
      <span>{{ n.html | safe }}</span>
    </div>
    {% endfor %}
  </div>
</aside>
{% endif %}

</div>
