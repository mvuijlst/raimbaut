---
layout: base.njk
pagination:
  data: edition.linearSections
  size: 1
  alias: section
permalink: "/{{ section.slug }}/"
eleventyComputed:
  title: "{{ section.title }}"
  bodyClass: "livre"
---
<div class="chanson-page section-page" id="study" data-view="web" data-livre="continue">

{# ================================================= VERSION WEB (lecture) #}
<div class="cx-view cx-web study prose-study{% if not section.notes.length %} no-notes{% endif %}">

<main class="study-main">
<article class="prose">
<header class="section-head">
  {% if section.kind == "conclusion" %}<span class="u-eyebrow">Vers une poétique de Raimbaut d'Orange</span>{% endif %}
  <h1>{{ section.title }}</h1>
  {% if section.subtitle %}<p class="incipit"><em>{{ section.subtitle }}</em></p>{% endif %}
  {% if section.note %}<p class="index-note">{{ section.note | safe }}</p>{% endif %}
</header>

<section class="edition-body{% if section.kind == 'index' %} index-body{% endif %}">
{% if section.concordance %}
<div class="concordance">
  <div class="cx-toolbar">
    <div class="cx-search-row">
      <div class="cx-search-wrap">
        <span class="cx-mag" aria-hidden="true">⌕</span>
        <input class="cx-filter" type="search" autocomplete="off" spellcheck="false" placeholder="aller au mot…" aria-label="Filtrer les mots">
        <button type="button" class="cx-clear" aria-label="Effacer la recherche" hidden>×</button>
      </div>
      <span class="cx-count" aria-live="polite">{{ section.concordance.count }} mots</span>
    </div>
    <nav class="cx-rail" aria-label="Index alphabétique">{{ section.concordance.railHTML | safe }}</nav>
  </div>
  <div class="cx-list">{{ section.concordance.listHTML | safe }}</div>
  <p class="cx-noresults" hidden>Aucun mot ne correspond à cette recherche.</p>
</div>
{% else %}
{{ section.html | safe }}
{% endif %}
</section>
</article>
</main>

{% if section.notes.length %}
<aside class="study-panel" id="panel" aria-label="Notes">
  <header class="panel-head">
    <span>Notes</span>
    <button type="button" class="resync" hidden>⟲ suivre le texte</button>
  </header>
  <div class="panel-scroll" id="panel-scroll">
    {% for n in section.notes %}
    <div class="fnote" id="fn-{{ n.label }}">
      <a class="fnote-n" href="#fnref-{{ n.label }}" aria-label="Retour à l'appel de note {{ n.n }}">{{ n.n }}</a>
      <span>{{ n.html | safe }}</span>
    </div>
    {% endfor %}
  </div>
</aside>
{% endif %}

</div>

{% if section.livre %}
{# ====================================== VERSION LIVRE — lecture continue #}
<div class="cx-view cx-livre study prose-study is-livre{% if not section.livre.notes.length %} no-notes{% endif %}">
<main class="study-main">
<article class="prose">
<section class="edition-body{% if section.kind == 'index' %} index-body{% endif %}">
{{ section.livre.html | safe }}
</section>
</article>
</main>
{% if section.livre.notes.length %}
<aside class="study-panel" aria-label="Notes">
  <header class="panel-head">
    <span>Notes</span>
    <button type="button" class="resync" hidden>⟲ suivre le texte</button>
  </header>
  <div class="panel-scroll">
    {% for n in section.livre.notes %}
    <div class="fnote" id="fn-{{ n.label }}">
      <a class="fnote-n" href="#fnref-{{ n.label }}" aria-label="Retour à l'appel de note {{ n.n }}">{{ n.n }}</a>
      <span>{{ n.html | safe }}</span>
    </div>
    {% endfor %}
  </div>
</aside>
{% endif %}
</div>

{# ===================================== VERSION LIVRE — fac-similé paginé #}
{% if section.livre.facsimile.length %}
<section class="cx-view cx-facsimile facsimile-body is-livre" aria-label="Fac-similé du tapuscrit">
  {% for pg in section.livre.facsimile %}
  <article class="fx-page"{% if pg.pid %} id="fx-page-{{ pg.pid }}"{% endif %}>
    <div class="fx-sheet">
      <div class="fx-content">{{ pg.html | safe }}</div>
      {% if pg.notes.length %}
      <div class="fx-notes">
        {% for n in pg.notes %}<p class="fx-note"><span class="fx-n">{{ n.n }}</span>{{ n.html | safe }}</p>{% endfor %}
      </div>
      {% endif %}
    </div>
    {% if pg.folio %}<div class="fx-folio">{{ pg.folio }}.</div>{% endif %}
  </article>
  {% endfor %}
</section>
{% endif %}
{% endif %}

</div>
